# Supabase (backend/database)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Stripe (payment processing) - 2025 Pricing
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
VITE_STRIPE_PRICE_PREMIUM_MONTHLY_AUD=price_1SJk4yEhyEZfSSpN8x8KqTGY
VITE_STRIPE_PRICE_PREMIUM_YEARLY_AUD=price_1SJk5EEhyEZfSSpNpADhN5AQ
VITE_STRIPE_PRICE_FAMILY_MONTHLY_AUD=price_1SJk5TEhyEZfSSpNKpDL6ZyO
VITE_STRIPE_PRICE_FAMILY_YEARLY_AUD=price_1SJk9JEhyEZfSSpNFATW8hkx

# Google Maps API (for address autocomplete)
VITE_GOOGLE_MAPS_API_KEY=

# Application URL
VITE_APP_URL=

# Optional: Document storage limits (MB)
VITE_FREE_DOCS_STORAGE_MB=0
VITE_PREMIUM_DOCS_STORAGE_MB=50
VITE_FAMILY_DOCS_STORAGE_MB=200

# Security Notes:
# - NEVER commit the actual .env file to version control
# - Rotate API keys regularly (every 90 days recommended)
# - Restrict Google Maps API key to:
#   * Specific domains (Application restrictions)
#   * Only required APIs (Maps JavaScript API, Places API)
# - Store production secrets in Lovable Cloud secrets management
# - VITE_* and NEXT_PUBLIC_* variables are exposed to client code
