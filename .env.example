# Supabase (backend/database)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Apple In-App Purchases (iOS subscriptions) - REQUIRED for iOS
VITE_APPLE_PRO_MONTHLY_PRODUCT_ID=
VITE_APPLE_PRO_YEARLY_PRODUCT_ID=

# App Store URL (for download links on web)
VITE_APP_STORE_URL=

# Stripe (LEGACY - web/admin only, not used for iOS subscriptions)
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
VITE_STRIPE_PRICE_PRO_MONTHLY_AUD=
VITE_STRIPE_PRICE_PRO_YEARLY_AUD=

# Google Maps API (for address autocomplete)
VITE_GOOGLE_MAPS_API_KEY=

# Application URL
VITE_APP_URL=

# Optional: Trial period (defaults to 7 days)
VITE_TRIAL_DAYS=7

# Optional: Document storage limits (MB)
VITE_FREE_DOCS_STORAGE_MB=100
VITE_PRO_DOCS_STORAGE_MB=5000

# Security Notes:
# - NEVER commit the actual .env file to version control
# - Rotate API keys regularly (every 90 days recommended)
# - Restrict Google Maps API key to:
#   * Specific domains (Application restrictions)
#   * Only required APIs (Maps JavaScript API, Places API)
# - Store production secrets in Lovable Cloud secrets management
# - VITE_* and NEXT_PUBLIC_* variables are exposed to client code
# - Apple product IDs must match those configured in App Store Connect
